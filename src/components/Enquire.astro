---
const year = new Date().getFullYear();
---

<section class="enquire" id="enquire">
  <div class="enquire-content">
    <h2 class="enquire-title">Stay.</h2>
    <div class="enquire-line"></div>
    <p class="enquire-meta">Malibu, California · Private Estate</p>
    <div class="enquire-contact">
      <a href="mailto:info@casaserena.com" class="enquire-email">info@casaserena.com</a>
      <a href="tel:+1-310-000-0000" class="enquire-phone">+1 (310) 000-0000</a>
    </div>
    <form class="enquire-form" novalidate>
      <div class="form-group">
        <label for="enquire-name" class="form-label">Name</label>
        <input id="enquire-name" type="text" name="name" class="form-input" autocomplete="name" required aria-required="true" />
      </div>
      <div class="form-group">
        <label for="enquire-email" class="form-label">Email</label>
        <input id="enquire-email" type="email" name="email" class="form-input" autocomplete="email" required aria-required="true" />
      </div>
      <div class="form-group">
        <label for="enquire-message" class="form-label">Message <span class="form-optional">(optional)</span></label>
        <textarea id="enquire-message" name="message" class="form-input form-textarea" rows="3"></textarea>
      </div>
      <button type="submit" class="form-submit">
        <span>Send Enquiry</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="2" y1="8" x2="14" y2="8"/><path d="M9 3l5 5-5 5"/></svg>
      </button>
    </form>
    <div class="enquire-social">
      {[
        { label: 'Instagram', href: 'https://instagram.com' },
        { label: 'Airbnb',    href: 'https://airbnb.com' },
        { label: 'Facebook',  href: 'https://facebook.com' },
      ].map((s, i, arr) => (
        <>
          <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
          {i < arr.length - 1 && <span>·</span>}
        </>
      ))}
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer-logo">CASA SERENA</div>
  <div class="footer-copyright">© {year}</div>
  <div class="footer-location">Malibu, California</div>
</footer>

<style>
.enquire {
  background: linear-gradient(to bottom, var(--warm-white) 52%, var(--charcoal) 52%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: clamp(4rem, 8vw, 8rem) 4vw 3rem;
}

.enquire-content {
  text-align: center;
  max-width: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.enquire-title {
  font-size: clamp(6rem, 10vw, 12rem);
  font-style: italic;
  font-weight: 300;
  color: var(--charcoal);
  line-height: 0.9;
}

.enquire-line {
  width: 60px;
  height: 1px;
  background: var(--terracotta);
}

.enquire-meta {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--driftwood);
}

.enquire-contact {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.enquire-email,
.enquire-phone {
  font-size: 1.8rem;
  color: var(--charcoal);
  transition: color 0.3s;
}

.enquire-email:hover,
.enquire-phone:hover {
  color: var(--terracotta);
}

.enquire-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
  max-width: 480px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  text-align: left;
}

.form-label {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--driftwood);
}

.form-optional {
  opacity: 0.6;
  font-style: italic;
  text-transform: none;
  letter-spacing: 0;
}

.form-input {
  width: 100%;
  border: none;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  background: transparent;
  font-size: 1rem;
  color: var(--cream);
  padding: 0.6rem 0;
  outline: none; /* focus handled by border-bottom-color on :focus */
  transition: border-color 0.3s;
  appearance: none;
  border-radius: 0;
}

.form-input:focus {
  border-bottom-color: var(--terracotta);
}

.form-textarea {
  resize: none;
  line-height: 1.6;
}

.form-submit {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  border: 1px solid rgba(255,255,255,0.25);
  background: transparent;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cream);
  cursor: pointer;
  padding: 0.85rem 1.8rem;
  transition: background 0.3s, border-color 0.3s;
  align-self: flex-start;
}

.form-submit:hover {
  background: var(--terracotta);
  border-color: var(--terracotta);
}

.enquire-social {
  font-size: 0.8rem;
  color: var(--driftwood);
}

.enquire-social a {
  color: var(--driftwood);
  transition: color 0.3s;
}

.enquire-social a:hover {
  color: var(--terracotta);
}

.enquire-social span {
  margin: 0 0.5rem;
}

.footer {
  border-top: 1px solid var(--terracotta);
  background: var(--charcoal);
  padding: 1.5rem 4vw;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-logo {
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  color: var(--cream);
}

.footer-copyright,
.footer-location {
  font-size: 0.7rem;
  color: var(--driftwood);
}

.footer-location {
  text-align: right;
}

.form-success {
  font-style: italic;
  color: var(--terracotta);
  font-size: 1.1rem;
}

@media (max-width: 768px) {
  .enquire-title {
    font-size: clamp(3rem, 8vw, 6rem);
  }

  .form-submit {
    width: 100%;
  }

  .footer {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }
}
</style>
