---
import { Image } from 'astro:assets';
---

<section class="hero">
  <div class="hero-bg">
    <Image src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1800&q=85" alt="Casa Serena exterior at golden hour" width={1800} height={1200} format="webp" quality={85} loading="eager" fetchpriority="high" />
  </div>
  <div class="hero-overlay-dark"></div>
  <div class="hero-overlay-grain"></div>
  
  <div class="hero-content">
    <div class="hero-eyebrow">
      {'BEACHFRONT ESTATE'.split('').map(c => <span class="ec">{c}</span>)}
    </div>
    <div class="hero-line"></div>
    <h1 class="hero-title">Serena</h1>
    <div class="hero-meta">Malibu CA · 4 Suites · 8 Acres · Beachfront</div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <div class="scroll-text">SCROLL</div>
  </div>
</section>

<div class="marquee-strip">
  <div class="marquee-container">
    <span class="marquee-text">PRIVATE ESTATE · MALIBU CALIFORNIA · BEACHFRONT · 4 SUITES · INFINITY POOL · </span>
    <span class="marquee-text">PRIVATE ESTATE · MALIBU CALIFORNIA · BEACHFRONT · 4 SUITES · INFINITY POOL · </span>
  </div>
</div>

<section class="intro">
  <div class="intro-left">
    <h2 class="intro-text">A house that breathes.</h2>
  </div>
  <div class="intro-right">
    <p>Designed to dissolve boundaries between interior and ocean, Casa Serena is where architecture whispers rather than shouts. Light becomes material here.</p>
  </div>
</section>

<style>
.hero {
  position: relative;
  width: 100%;
  height: 100svh;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay-dark {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at bottom left, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.7));
  z-index: 2;
}

.hero-overlay-grain {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' seed='2' /%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  z-index: 3;
  opacity: 0.4;
  pointer-events: none;
}

.hero-content {
  position: absolute;
  bottom: 4vw;
  left: 4vw;
  z-index: 4;
  max-width: 600px;
}

.hero-eyebrow {
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--cream);
  margin-bottom: 1.5rem;
  display: flex;
  flex-wrap: wrap;
}

.hero-eyebrow .ec {
  display: inline-block;
}

.hero-line {
  width: 64px;
  height: 1px;
  background: var(--terracotta);
  margin-bottom: 2rem;
  transform-origin: left;
}

.hero-title {
  font-size: clamp(5rem, 13vw, 14rem);
  font-style: italic;
  font-weight: 300;
  color: var(--cream);
  line-height: 0.85;
  margin-bottom: 1.5rem;
}

.hero-meta {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(245, 240, 232, 0.7);
}

.hero-scroll {
  position: absolute;
  bottom: 4vw;
  right: 4vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  z-index: 4;
}

.scroll-text {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cream);
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
}

.scroll-line {
  width: 1px;
  height: 0;
  background: var(--terracotta);
  animation: scrollLine 2s infinite;
}

@keyframes scrollLine {
  0% {
    height: 0;
    opacity: 1;
  }
  70% {
    height: 40px;
    opacity: 1;
  }
  100% {
    height: 40px;
    opacity: 0;
  }
}

.marquee-strip {
  width: 100%;
  height: 44px;
  background: var(--terracotta);
  overflow: hidden;
  display: flex;
  align-items: center;
}

.marquee-container {
  display: flex;
  animation: marqueeScroll 20s linear infinite;
  white-space: nowrap;
}

.marquee-text {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cream);
  flex-shrink: 0;
  padding-right: 2rem;
}

@keyframes marqueeScroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.intro {
  background: var(--warm-white);
  padding: 12vh 4vw;
  display: grid;
  grid-template-columns: 70% 30%;
  gap: 4vw;
  align-items: center;
}

.intro-left {
  display: flex;
  align-items: center;
}

.intro-text {
  font-size: clamp(3.5rem, 9vw, 10rem);
  font-style: italic;
  font-weight: 300;
  color: var(--charcoal);
  line-height: 1.1;
}

.intro-right {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding-left: 2rem;
  border-left: 1px solid var(--terracotta);
}

.intro-right p {
  font-size: 0.95rem;
  color: var(--driftwood);
  text-align: right;
  line-height: 1.7;
}

@media (max-width: 768px) {
  .intro {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .intro-text {
    font-size: clamp(2rem, 7vw, 3.5rem);
  }

  .intro-right {
    padding-left: 1.5rem;
  }

  .intro-right p {
    text-align: left;
    font-size: 0.9rem;
  }
}
</style>
